# OpenGOV backend — env template. Copy to `.env` (gitignored) and fill in.
# `.env` is loaded at startup by src/config/dotenv.ts; real env vars take precedence.

# Required for live /chat answers + golden-qa. Get one at https://openrouter.ai/keys
# Leave empty to run key-optional: server boots, /chat is fail-closed, llm_check disabled.
OPENROUTER_API_KEY=

# Optional overrides (sensible defaults shown):
# PORT=3001
# OPENROUTER_STRONG_MODEL=deepseek/deepseek-v4-pro
# OPENROUTER_CHEAP_MODEL=deepseek/deepseek-v4-pro
# OPENROUTER_FALLBACK_MODEL=tencent/hy3:free,nvidia/nemotron-3-ultra-550b-a55b:free
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# OPENROUTER_REFERER=
# OPENROUTER_TITLE=OpenGOV
# Path overrides (default: DB at backend/var/opengov.db, data at repo data/):
# OPENGOV_DB_PATH=
# OPENGOV_DATA_DIR=
